# Knowledge App – environment overrides
# Copy this file to .env and adjust values. Never commit .env.
#
# All settings here take precedence over config.yaml.

# ─── Ports ─────────────────────────────────────────────────────────────────────
KNOWLEDGE_APP_PORT=8000
FRONTEND_PORT=8080
OLLAMA_PORT=11434

# ─── Ollama model ──────────────────────────────────────────────────────────────
# Recommended for Intel Mac (CPU):
#   qwen2.5:latest  – best quality, good Czech + English (7B)
#   phi3:latest     – fastest, good for 8 GB RAM (3.8B)
#   llama3.2:3b     – lightweight alternative
OLLAMA_MODEL=qwen2.5:latest

# ─── App config (mirrors config.yaml env-var names) ────────────────────────────
# KNOWLEDGE_APP_LLM_MODEL=phi3:latest
# KNOWLEDGE_APP_DB_PATH=./backend/data/knowledge.db

# ─── Security ──────────────────────────────────────────────────────────────────
# Uncomment to enable API-key auth (all /api/v1/* endpoints except /health)
# KNOWLEDGE_APP_API_KEY=change-me-to-a-secret

# ─── Dev options ───────────────────────────────────────────────────────────────
# Set to 1 to skip `git pull` on startup (useful when working offline)
# SKIP_GIT_PULL=1
