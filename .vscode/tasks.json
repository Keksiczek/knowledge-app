    {
      "label": "Knowledge App: Pull Ollama model",
      "type": "shell",
      "command": "make pull-model",
      "group": "none",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
