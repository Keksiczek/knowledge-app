{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Knowledge App: Run (dev)",
      "type": "shell",
      "command": "./run-app.sh dev",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": [],
      "runOptions": {
        "instanceLimit": 1
      }
    },
    {
      "label": "Knowledge App: Run (prod)",
      "type": "shell",
      "command": "./run-app.sh prod",
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": [],
      "runOptions": {
        "instanceLimit": 1
      }
    },
    {
      "label": "Knowledge App: Stop",
      "type": "shell",
      "command": "make stop",
      "group": "none",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Knowledge App: Setup (install deps only)",
      "type": "shell",
      "command": "make setup",
      "group": "none",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Knowledge App: Tail logs",
      "type": "shell",
      "command": "tail -f knowledge-app.log",
